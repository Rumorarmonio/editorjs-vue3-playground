    {
      "id": "code-snippet-javascript-block",
      "type": "codeSnippet",
      "data": {
        "language": "javascript",
        "code": "const listeners = new Map()\nconst eventPattern = /^(open|close|toggle):[a-z-]+$/\n\nexport async function emitEditorEvent(name, payload = {}) {\n  if (!eventPattern.test(name)) {\n    throw new TypeError(`Unsupported event: ${name}`)\n  }\n\n  const handlers = listeners.get(name) ?? []\n  const context = { name, payload, timestamp: Date.now() }\n\n  try {\n    await Promise.all(handlers.map((handler) => handler(context)))\n  } catch (error) {\n    console.error('Editor event failed', { name, error })\n  }\n}",
        "caption": "JavaScript example covers async functions, regex, template strings, errors, objects and Promise APIs."
      },
      "tunes": {
        "spacing": {
          "top": "small"
        },
        "label": {
          "label": "JavaScript"
        },
        "animation": {
          "type": "fade-right"
        }
      }
    },
    {
      "id": "code-snippet-vue-block",
      "type": "codeSnippet",
      "data": {
        "language": "vue",
        "code": "<script setup lang=\"ts\">\nconst props = withDefaults(defineProps<{\n  title: string\n  items: Array<{ id: string; label: string; active?: boolean }>\n}>(), {\n  title: 'Renderer blocks',\n})\n\nconst emit = defineEmits<{\n  select: [id: string]\n}>()\n</script>\n\n<template>\n  <section class=\"feature-list\" :aria-label=\"props.title\">\n    <h2>{{ props.title }}</h2>\n    <button\n      v-for=\"item in props.items\"\n      :key=\"item.id\"\n      :class=\"['feature-list__item', { 'is-active': item.active }]\"\n      type=\"button\"\n      @click=\"emit('select', item.id)\"\n    >\n      <slot name=\"icon\" :item=\"item\" />\n      {{ item.label }}\n    </button>\n  </section>\n</template>\n\n<style scoped>\n.feature-list__item.is-active {\n  color: var(--color-accent);\n}\n</style>",
        "caption": "Vue example covers script setup, typed props/emits, directives, events, slots, bindings and scoped styles."
