        "code": "{\n  \"time\": 1747324800000,\n  \"blocks\": [\n    {\n      \"id\": \"cta-block-event\",\n      \"type\": \"cta\",\n      \"data\": {\n        \"label\": \"Open preview workflow\",\n        \"url\": \"/preview\",\n        \"variant\": \"primary\",\n        \"target\": \"sameTab\",\n        \"enabled\": true,\n        \"analytics\": null,\n        \"priority\": 2\n      }\n    }\n  ],\n  \"version\": \"2.31.0\"\n}",
        "caption": "JSON example covers nested arrays and objects, strings, numbers, booleans and null."
