    {
      "id": "code-snippet-block",
      "type": "codeSnippet",
      "data": {
        "language": "typescript",
        "code": "import type { EditorOutputBlock } from './types'\n\ntype CtaBlockTarget = 'sameTab' | 'newTab'\ntype CtaVariant = 'primary' | 'secondary' | 'ghost'\n\ninterface CtaBlockData<TMeta extends Record<string, unknown> = {}> {\n  label: string\n  url: `/${string}` | `https://${string}`\n  variant: CtaVariant\n  target: CtaBlockTarget\n  meta?: TMeta\n}\n\nconst ctaDefaults = {\n  variant: 'primary',\n  target: 'sameTab',\n} satisfies Pick<CtaBlockData, 'variant' | 'target'>\n\nexport function normalizeCtaBlock(\n  block: EditorOutputBlock<'cta', Partial<CtaBlockData>>,\n): CtaBlockData {\n  // Keep admin-entered labels readable in the renderer.\n  const label = block.data.label?.trim() || 'Open preview'\n  const url = /^https?:\\/\\//.test(block.data.url ?? '') ? block.data.url! : '/preview'\n\n  return { ...ctaDefaults, ...block.data, label, url }\n}",
        "caption": "TypeScript example covers imports, generics, unions, template literal types, satisfies, comments, regex and object spreads."
      },
      "tunes": {
        "anchor": {
          "anchor": "code-snippet"
        },
        "spacing": {
          "top": "medium"
        },
        "label": {
          "label": "Code snippet"
        },
        "animation": {
          "type": "fade-left"
        }
      }
    },
