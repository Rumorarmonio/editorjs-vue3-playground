    {
      "id": "code-snippet-bash-block",
      "type": "codeSnippet",
      "data": {
        "language": "bash",
        "code": "# Run focused checks before publishing\nset -euo pipefail\n\nTARGET=\"content/default-page.json\"\nnode -e \"JSON.parse(require('fs').readFileSync(process.argv[1], 'utf8'))\" \"$TARGET\"\n\nif npm run build; then\n  printf 'Build finished for %s\\n' \"$TARGET\"\nelse\n  echo \"Build failed\" >&2\n  exit 1\nfi",
        "caption": "Shell example covers comments, variables, strings, conditionals, commands and redirects."
      },
      "tunes": {
